
FROM node:20-alpine AS build

WORKDIR /app

# Copiar manifiestos 

COPY package.json package-lock.json ./
RUN npm ci --silent

# Copiar el resto del código y compilar
COPY . .

# VITE_API_URL en blanco → el frontend usa /api (relativo), que Nginx redirige al backend. 
ARG VITE_API_URL=""
ENV VITE_API_URL=${VITE_API_URL}

RUN npm run build

# Montar con Nginx
FROM nginx:1.27-alpine AS serve

# Eliminar configuración default de Nginx
RUN rm /etc/nginx/conf.d/default.conf

# Copiar nuestra configuración
COPY nginx.conf /etc/nginx/conf.d/dashboard.conf

# Copiar el bundle compilado por Vite al directorio que sirve Nginx
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
