# ── Base de datos ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://usuario:contraseña@host:puerto/nombre_db

# ── Seguridad JWT ──────────────────────────────────────────────────────────────
# Genera una clave segura con: openssl rand -hex 32
SECRET_KEY=reemplaza_esto_con_una_clave_de_minimo_32_caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Credenciales del administrador ─────────────────────────────────────────────
ADMIN_USERNAME=admin
# Genera el hash con:
# python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('tu_contraseña'))"
ADMIN_PASSWORD_HASH=

# ── Supabase ──────────────────────────────────────────────────────────────────
# Requeridas para usar la API REST de Supabase (Storage, RLS, Data API, etc.)
# SUPABASE_URL se encuentra en: Supabase Dashboard → Settings → General → Project URL
# SUPABASE_SECRET_KEY se encuentra en: Supabase Dashboard → Settings → API Keys → Secret keys
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...

# ── Entorno ────────────────────────────────────────────────────────────────────
# Valores: development | production
ENVIRONMENT=development

# ── CORS ───────────────────────────────────────────────────────────────────────
# En producción, reemplazar con la URL real del frontend
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
